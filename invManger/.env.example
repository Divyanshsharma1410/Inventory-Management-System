# ---------------------------------------------------------------
# Root environment for docker-compose. Copy to .env and edit.
#   cp .env.example .env
# Never commit the real .env file.
# ---------------------------------------------------------------

# --- Database ---
POSTGRES_USER=invuser
POSTGRES_PASSWORD=invpass
POSTGRES_DB=inventory

# --- Backend ---
NODE_ENV=production
# IMPORTANT: change this to a long random string for any real deployment
JWT_SECRET=please-change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Seed admin account (created on first boot)
SEED_ADMIN_EMAIL=admin@inventory.local
SEED_ADMIN_PASSWORD=Admin@123

# --- Host port mapping ---
FRONTEND_PORT=8080
BACKEND_PORT=4000
