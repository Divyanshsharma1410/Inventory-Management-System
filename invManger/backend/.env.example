# --- Backend environment variables ---
# Copy to .env and adjust. Never commit real secrets.

NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://invuser:invpass@localhost:5432/inventory?schema=public

# JWT signing secret — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS: comma-separated origins, or * for all
CORS_ORIGIN=*

# Seed admin credentials (used by prisma/seed.js)
SEED_ADMIN_EMAIL=admin@inventory.local
SEED_ADMIN_PASSWORD=Admin@123
