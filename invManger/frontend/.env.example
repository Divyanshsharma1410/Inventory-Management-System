# --- Frontend environment variables (Vite) ---
# Only variables prefixed with VITE_ are exposed to the browser.

# API base URL. Leave as /api to use the nginx/dev proxy (recommended).
# Set to a full URL (e.g. https://api.example.com/api) when the backend
# is deployed on a separate origin.
VITE_API_URL=/api

# Dev-only: where the Vite dev server proxies /api to.
VITE_PROXY_TARGET=http://localhost:4000
